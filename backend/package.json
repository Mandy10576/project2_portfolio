{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "description": "Production-Ready Express.js Backend with Prisma ORM for Portfolio CMS",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "node src/utils/seed.js",
    "vercel-build": "prisma generate"
  },
  "keywords": [
    "nodejs",
    "express",
    "prisma",
    "postgresql",
    "jwt",
    "cms",
    "portfolio"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "prisma": "^5.12.1"
  }
}
